{
  "name": "MarkerDetectorApp",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready computer vision marker detection app for Android",
  "scripts": {
    "android": "react-native run-android",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.6",
    "react-native-vision-camera": "^4.0.1",
    "react-native-reanimated": "^3.7.2",
    "react-native-worklets-core": "^1.3.3",
    "@shopify/react-native-skia": "^1.2.3",
    "react-native-gesture-handler": "^2.16.1",
    "react-native-safe-area-context": "^4.10.1",
    "react-native-screens": "^3.31.1",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/stack": "^6.3.29",
    "react-native-svg": "^15.3.0",
    "react-native-haptic-feedback": "^2.2.0",
    "react-native-device-info": "^11.1.0",
    "react-native-permissions": "^4.1.5",
    "@shopify/flash-list": "^1.6.4",
    "zustand": "^4.5.2",
    "immer": "^10.1.1",
    "date-fns": "^3.6.0",
    "patch-package": "^8.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.24.4",
    "@babel/runtime": "^7.24.4",
    "@react-native/babel-preset": "^0.73.21",
    "@react-native/eslint-config": "^0.73.2",
    "@react-native/metro-config": "^0.73.5",
    "@react-native/typescript-types": "^0.73.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.79",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^18.0.7",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-native": "^4.1.0",
    "jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "prettier": "^3.2.5",
    "react-test-renderer": "18.2.0",
    "react-native-svg-transformer": "^1.4.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json"
    ],
    "setupFilesAfterFramework": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|react-native-vision-camera|react-native-reanimated|react-native-worklets-core|react-native-skia|react-native-gesture-handler|react-native-safe-area-context|react-native-screens|react-native-svg|react-native-haptic-feedback|react-native-device-info|react-native-permissions|@shopify/flash-list)/)"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "printWidth": 100,
    "tabWidth": 2,
    "bracketSpacing": true,
    "semi": true
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}